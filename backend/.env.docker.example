# ── backend/.env.docker ──────────────────────────────────────────────
# Окружение для контейнеров api / api-migrate (docker compose).
# Скопируй:  cp backend/.env.docker.example backend/.env.docker
#
# ВАЖНО: файл готов к ЛОКАЛЬНОМУ запуску КАК ЕСТЬ — менять ничего не нужно.
# Секреты ниже — валидные dev-заглушки достаточной длины, стек поднимется,
# админка и API заработают сразу.
#
# Для ПРОДА: замени секреты (openssl rand -hex 32), поставь ENVIRONMENT=production,
# реальный MAX_BOT_TOKEN и PUBLIC_BASE_URL — подробности в DEPLOY.md.
# Файл backend/.env.docker — gitignored, в репозиторий не попадает.

# development | production  (production отключает dev-удобства)
ENVIRONMENT=development
PYTHONPATH=/app

# Пароль (после app:) ОБЯЗАН совпадать с POSTGRES_PASSWORD в корневом .env.
# Значение литеральное — подстановки ${...} в env_file НЕ работают.
DATABASE_URL=postgresql+asyncpg://app:localdev@postgres:5432/mirea_max

# JWT для веб-админки. МИНИМУМ 32 символа, иначе старт упадёт. Прод: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-me-0123456789abcdef

# Токен бота MAX (кабинет разработчика). Без реального токена бот не отвечает,
# но админка/API/моки работают локально и без него (ошибки long-poll в логах — это норм).
MAX_BOT_TOKEN=dev-placeholder-token
MAX_API_BASE_URL=https://platform-api.max.ru

# long_poll (локально/dev) | webhook (прод за HTTPS)
MAX_TRANSPORT=long_poll

# Секрет вебхука — MAX подписывает им запросы. Минимум 5 символов (на long_poll не используется).
WEBHOOK_SECRET=dev-webhook-secret

# Секрет подписи QR. МИНИМУМ 32 символа. Прод: openssl rand -hex 32
QR_SERVER_SECRET=dev-qr-secret-change-me-0123456789abcdef

# Публичный HTTPS-адрес — кнопки в боте + регистрация вебхука. Локально можно пусто.
PUBLIC_BASE_URL=

# Опционально: ссылка на бота для QR-приглашений события.
# Пусто — кнопка «Поделиться QR» сгенерит QR с текстовым payload event_<uuid>.
# Пример: https://max.ru/your_bot_username
BOT_SHARE_URL=

UPLOAD_DIR=/data/uploads
