# ── backend/.env ──────────────────────────────────────────────────────
# Для запуска бэкенда БЕЗ Docker (локальный uvicorn).
# Скопируй:  cp backend/.env.example backend/.env
# Готово к локальному запуску КАК ЕСТЬ. Подразумевает Postgres на localhost:5432
# (пользователь app / пароль localdev / база mirea_max). Файл .env — gitignored.

ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://app:localdev@localhost:5432/mirea_max

# JWT и QR — МИНИМУМ 32 символа (иначе старт упадёт). Прод: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-me-0123456789abcdef
QR_SERVER_SECRET=dev-qr-secret-change-me-0123456789abcdef

# Бот не отвечает без реального токена, но API/админка работают локально и без него.
MAX_BOT_TOKEN=dev-placeholder-token
MAX_TRANSPORT=long_poll
WEBHOOK_SECRET=dev-webhook-secret

UPLOAD_DIR=/tmp/uploads
