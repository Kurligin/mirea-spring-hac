# ── Корневой .env ────────────────────────────────────────────────────
# Переменные уровня docker compose. Скопируй в .env:  cp .env.example .env
# Готово к локальному запуску КАК ЕСТЬ — менять ничего не нужно.
# Файл .env — gitignored, в репозиторий не попадает.

# Пароль БД. Должен совпадать с паролем в backend/.env.docker → DATABASE_URL.
# Для локалки оставь как есть; для прода — поставь свой.
POSTGRES_PASSWORD=localdev

# ── Только для прод-деплоя (docker-compose.prod.yml). Локально не используются. ──
# Домен с A-записью на сервер.
DEPLOY_DOMAIN=example.com
# Email для Let's Encrypt (уведомления об истечении сертификата).
CERTBOT_EMAIL=admin@example.com
